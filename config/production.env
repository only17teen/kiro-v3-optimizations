# Kiro Protocol v3.0 - Production Environment Configuration

# Application
KIRO_ENV=production
KIRO_LOG_LEVEL=warning
KIRO_DEBUG=false

# Server
KIRO_HOST=0.0.0.0
KIRO_PORT=8080
KIRO_METRICS_PORT=9090

# Database
POSTGRES_HOST=postgres.production.internal
POSTGRES_PORT=5432
POSTGRES_DB=kiro_v3_prod
POSTGRES_USER=kiro_prod
POSTGRES_PASSWORD=${PROD_POSTGRES_PASSWORD}
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# Redis
REDIS_HOST=redis.production.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=50

# GPU
CUDA_VISIBLE_DEVICES=0,1,2,3
KIRO_GPU_MEMORY_FRACTION=0.95
KIRO_GPU_ALLOW_GROWTH=false

# LLM
KIRO_DEFAULT_MODEL=gpt-4
KIRO_MAX_TOKENS=8192
KIRO_TEMPERATURE=0.7
KIRO_TIMEOUT=120.0

# Tracing
KIRO_TRACING_ENABLED=true
KIRO_OTLP_ENDPOINT=http://jaeger.production.internal:4317
KIRO_TRACING_SAMPLE_RATE=0.1

# Metrics
KIRO_METRICS_ENABLED=true
KIRO_PROMETHEUS_ENABLED=true
KIRO_METRICS_FLUSH_INTERVAL=15.0

# Cache
KIRO_CACHE_ENABLED=true
KIRO_CACHE_MAX_SIZE=100000
KIRO_CACHE_TTL=1800

# Security
KIRO_JWT_SECRET=${PROD_JWT_SECRET}
KIRO_JWT_EXPIRY=1800
KIRO_RATE_LIMIT_ENABLED=true
KIRO_CORS_ORIGINS=https://kiro-v3.io,https://app.kiro-v3.io

# Scaling
KIRO_MIN_WORKERS=5
KIRO_MAX_WORKERS=50
KIRO_SCALE_UP_THRESHOLD=0.8
KIRO_SCALE_DOWN_THRESHOLD=0.2

# Feature Flags
KIRO_ENABLE_BANDIT=true
KIRO_ENABLE_PRECOGNITION=true
KIRO_ENABLE_TRACING=true
KIRO_ENABLE_CHAOS_TESTING=false

# High Availability
KIRO_ENABLE_MULTI_REGION=true
KIRO_PRIMARY_REGION=us-east-1
KIRO_BACKUP_REGIONS=us-west-2,eu-west-1
KIRO_FAILOVER_STRATEGY=active-active

# Disaster Recovery
KIRO_BACKUP_ENABLED=true
KIRO_BACKUP_INTERVAL=3600
KIRO_RPO_SECONDS=30
KIRO_RTO_SECONDS=300
