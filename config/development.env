# Kiro Protocol v3.0 - Development Environment Configuration

# Application
KIRO_ENV=development
KIRO_LOG_LEVEL=debug
KIRO_DEBUG=true

# Server
KIRO_HOST=0.0.0.0
KIRO_PORT=8080
KIRO_METRICS_PORT=9090

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kiro_v3_dev
POSTGRES_USER=kiro_dev
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=10

# GPU
CUDA_VISIBLE_DEVICES=0
KIRO_GPU_MEMORY_FRACTION=0.8
KIRO_GPU_ALLOW_GROWTH=true

# LLM
KIRO_DEFAULT_MODEL=gpt-4
KIRO_MAX_TOKENS=2048
KIRO_TEMPERATURE=0.7
KIRO_TIMEOUT=30.0

# Tracing
KIRO_TRACING_ENABLED=true
KIRO_OTLP_ENDPOINT=http://localhost:4317
KIRO_TRACING_SAMPLE_RATE=1.0

# Metrics
KIRO_METRICS_ENABLED=true
KIRO_PROMETHEUS_ENABLED=true
KIRO_METRICS_FLUSH_INTERVAL=5.0

# Cache
KIRO_CACHE_ENABLED=true
KIRO_CACHE_MAX_SIZE=1000
KIRO_CACHE_TTL=300

# Security
KIRO_JWT_SECRET=dev_secret_change_me_in_production
KIRO_JWT_EXPIRY=3600
KIRO_RATE_LIMIT_ENABLED=false
KIRO_CORS_ORIGINS=*

# Scaling
KIRO_MIN_WORKERS=1
KIRO_MAX_WORKERS=4
KIRO_SCALE_UP_THRESHOLD=0.7
KIRO_SCALE_DOWN_THRESHOLD=0.3

# Feature Flags
KIRO_ENABLE_BANDIT=true
KIRO_ENABLE_PRECOGNITION=true
KIRO_ENABLE_TRACING=true
KIRO_ENABLE_CHAOS_TESTING=false
