# Kiro Protocol v3.0 - Staging Environment Configuration

# Application
KIRO_ENV=staging
KIRO_LOG_LEVEL=info
KIRO_DEBUG=false

# Server
KIRO_HOST=0.0.0.0
KIRO_PORT=8080
KIRO_METRICS_PORT=9090

# Database
POSTGRES_HOST=postgres.staging.internal
POSTGRES_PORT=5432
POSTGRES_DB=kiro_v3_staging
POSTGRES_USER=kiro_staging
POSTGRES_PASSWORD=${STAGING_POSTGRES_PASSWORD}
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Redis
REDIS_HOST=redis.staging.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=20

# GPU
CUDA_VISIBLE_DEVICES=0,1
KIRO_GPU_MEMORY_FRACTION=0.9
KIRO_GPU_ALLOW_GROWTH=false

# LLM
KIRO_DEFAULT_MODEL=gpt-4
KIRO_MAX_TOKENS=4096
KIRO_TEMPERATURE=0.7
KIRO_TIMEOUT=60.0

# Tracing
KIRO_TRACING_ENABLED=true
KIRO_OTLP_ENDPOINT=http://jaeger.staging.internal:4317
KIRO_TRACING_SAMPLE_RATE=0.5

# Metrics
KIRO_METRICS_ENABLED=true
KIRO_PROMETHEUS_ENABLED=true
KIRO_METRICS_FLUSH_INTERVAL=10.0

# Cache
KIRO_CACHE_ENABLED=true
KIRO_CACHE_MAX_SIZE=10000
KIRO_CACHE_TTL=600

# Security
KIRO_JWT_SECRET=${STAGING_JWT_SECRET}
KIRO_JWT_EXPIRY=3600
KIRO_RATE_LIMIT_ENABLED=true
KIRO_CORS_ORIGINS=https://staging.kiro-v3.io

# Scaling
KIRO_MIN_WORKERS=2
KIRO_MAX_WORKERS=10
KIRO_SCALE_UP_THRESHOLD=0.75
KIRO_SCALE_DOWN_THRESHOLD=0.25

# Feature Flags
KIRO_ENABLE_BANDIT=true
KIRO_ENABLE_PRECOGNITION=true
KIRO_ENABLE_TRACING=true
KIRO_ENABLE_CHAOS_TESTING=true
